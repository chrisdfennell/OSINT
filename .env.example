# FlightRadar24 API token ($9/mo Explorer: https://fr24api.flightradar24.com)
# Without this, falls back to free adsb.lol hotspot polling
FR24_API_TOKEN=your_api_token_here

# AISStream.io API key (free: https://aisstream.io/authenticate)
AISSTREAM_API_KEY=your_api_key_here

# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
OWM_API_KEY=your_api_key_here

# YouTube Data API key (free: https://developers.google.com/youtube/v3/getting-started)
YOUTUBE_API_KEY=

# NASA FIRMS MAP_KEY for raw thermal-hotspot feed (free: https://firms.modaps.eosdis.nasa.gov/api/map_key/)
# Without this, the FIRMS layer stays empty (EONET fires still work).
FIRMS_MAP_KEY=

# Mapillary access token for the Ground View tool (free: https://www.mapillary.com/dashboard/developers)
# Without this, the Ground View picker reports "not configured".
MAPILLARY_TOKEN=